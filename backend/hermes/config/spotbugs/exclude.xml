<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!--
        EI_EXPOSE_REP / EI_EXPOSE_REP2: Lombok-generated getters/constructors on JPA entities
        return/store mutable objects (e.g. byte[], Date, List). These are false positives in the
        context of Spring Data JPA entities and DTOs where Lombok is used for boilerplate generation.
    -->
    <Match>
            <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <!--
        SECSQLISPRJDBC: MaterializedViewService constructs DDL statements (CREATE, DROP,
        REFRESH MATERIALIZED VIEW) from internally-sourced MV names that are validated
        against a registry. These are not user-input SQL injections.
    -->
    <Match>
        <Class name="com.trinity.hermes.mv.service.MaterializedViewService"/>
        <Bug pattern="SECSQLISPRJDBC"/>
    </Match>

    <!--
        SECRD (ReDOS): The regex in MaterializedViewService validates MV names against a
        known safe character set. Input is always an internally-registered name, not
        arbitrary user input, so a ReDoS attack is not a realistic threat.
    -->
    <Match>
        <Class name="com.trinity.hermes.mv.service.MaterializedViewService"/>
        <Bug pattern="SECRD"/>
    </Match>

    <!--
        SECCRLFLOG: Log statements that include request/path parameters may technically
        allow CRLF injection, but all endpoints are authenticated internal APIs.
        Sanitising every log parameter would add noise with no real security benefit here.
    -->
    <Match>
        <BugCode name="SECCRLFLOG"/>
    </Match>

    <!--
        SECSQLISPRJDBC: MaterializedViewService builds DDL strings (CREATE MATERIALIZED VIEW,
        REFRESH) from internal config only — no user input is ever interpolated.
        Parameterised queries cannot be used for DDL statements in PostgreSQL.
    -->
    <Match>
        <Class name="com.trinity.hermes.mv.service.MaterializedViewService"/>
        <BugCode name="SECSQLISPRJDBC"/>
    </Match>

    <!--
        SECRD: The regex in MaterializedViewService validates internal view-name identifiers
        sourced from application config, not user input. ReDOS is not a realistic threat.
    -->
    <Match>
        <Class name="com.trinity.hermes.mv.service.MaterializedViewService"/>
        <BugCode name="SECRD"/>
    </Match>
</FindBugsFilter>
